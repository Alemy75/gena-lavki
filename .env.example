# Local development: подними только БД — `docker compose up -d db` (порт 5432 проброшен на localhost)
DATABASE_URL="postgresql://catalog:catalog@localhost:5432/catalog?schema=public"

# Inside Docker Compose the hostname is `db` (see docker-compose.yml).

# Fill catalog_item: `pnpm db:seed` (with DATABASE_URL), or:
# `docker compose exec app node prisma/seed.js`
