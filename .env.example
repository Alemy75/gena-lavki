# Local development: подними только БД — `docker compose up -d db` (порт 5432 проброшен на localhost)
DATABASE_URL="postgresql://catalog:catalog@localhost:5432/catalog?schema=public"

# NextAuth (обязательно в проде; для dev можно оставить пример ниже)
# Сгенерировать: openssl rand -base64 32
AUTH_SECRET="replace-with-openssl-rand-base64-32"
# URL приложения (для cookies / редиректов)
AUTH_URL="http://localhost:3000"

# Первый админ при `pnpm db:seed` (потом меняй пароль в БД или пересидь)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="admin123"

# Inside Docker Compose the hostname is `db` (see docker-compose.yml).

# Fill catalog_item: `pnpm db:seed` (with DATABASE_URL), or:
# `docker compose exec app node prisma/seed.js`

# Форма «Связаться с нами» — отправка через Яндекс SMTP
# В Яндекс.Почте: включите доступ по IMAP/SMTP и создайте «Пароль приложения» (не пароль от аккаунта).
# SMTP_USER — полный адрес вида user@yandex.ru; FROM в письме совпадает с ним.
SMTP_HOST="smtp.yandex.ru"
# 465 — SSL; если таймаут на CONN, попробуйте 587 (STARTTLS), часто не блокируют
SMTP_PORT="587"
SMTP_USER="your-mail@yandex.ru"
SMTP_PASSWORD="yandex-app-password"
# Куда доставлять заявки (часто совпадает с SMTP_USER)
CONTACT_MAIL_TO="your-mail@yandex.ru"
# Для smtp.yandex.ru по умолчанию используется IPv4 (см. lib/smtp shouldForceIpv4). Отключить: SMTP_FORCE_IPV4=0
# Диагностика: в терминале из catalog — pnpm smtp:test
# Подробный лог SMTP в консоли сервера: CONTACT_SMTP_DEBUG=1
# Если письмо отклоняется после входа: CONTACT_OMIT_REPLY_TO=1 (без заголовка Reply-To)
# Отключить пресет nodemailer «Yandex» (если нужен свой порт): SMTP_USE_YANDEX_PRESET=0

# Если с вашей сети недоступен SMTP (оба порта — timeout): pnpm smtp:diagnose
# Сохранять заявку в БД при ошибке почты (таблица contact_message, смотреть в Prisma Studio):
# CONTACT_SAVE_IF_MAIL_FAILS=1
