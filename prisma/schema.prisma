generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Category {
  id        Int           @id @default(autoincrement())
  name      String        @unique
  sortOrder Int           @default(0)
  items     CatalogItem[]

  @@map("category")
}

model CatalogItem {
  id          Int       @id @default(autoincrement())
  name        String
  description String    @default("")
  image       String
  createdAt   DateTime  @default(now())
  categoryId  Int?
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@map("catalog_item")
}

model SiteSettings {
  id      Int    @id @default(1)
  phone   String @default("")
  address String @default("")

  @@map("site_settings")
}

model SocialLink {
  id        Int    @id @default(autoincrement())
  label     String
  url       String
  icon      String @default("")
  sortOrder Int    @default(0)

  @@map("social_link")
}

/// Заявки с формы, если SMTP недоступен и включён CONTACT_SAVE_IF_MAIL_FAILS
model ContactMessage {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  name      String
  email     String
  phone     String
  consent   Boolean

  @@map("contact_message")
}
